# .env.smoke.example — Plan #42 PR2 DX bundle
#
# This is the smoke-relevant subset of env vars for running the probe locally
# against the production code path:
#
#   python -m orchestrator.smoke_probe --local --check all
#
# Copy to `.env.smoke`, fill in the real values, then `source .env.smoke`
# before running the probe.

# ─── Check A: build_commit_match ─────────────────────────────────────────
# Production: Dockerfile/Railway sets this at container build time. Local
# laptops will not normally have it. With --local missing BUILD_COMMIT is a
# WARN, not a FAIL — Check A passes with a "WARN: BUILD_COMMIT unset (local
# mode)" detail. Set this only if you specifically want to test the mismatch
# branch.
BUILD_COMMIT=

# ─── Check B: dump_sf_query against Acme SF ──────────────────────────
# Check B runs the canonical sf_dump_tool.dump_sf_query path with
# `SELECT Id FROM Account LIMIT 1`. The portco key is hard-coded to
# "acme"; supply whichever credential mode that portco's
# portco_config.json entry uses:
#
# (a) OAuth Client Credentials Flow (preferred for SSO-enforced orgs):
SF_ACME_CONSUMER_KEY=3MVG9...
SF_ACME_CONSUMER_SECRET=...
SF_ACME_DOMAIN=https://your-org.my.salesforce.com

# (b) Legacy SOAP password + token (only if "Password Login" is not disabled
#     on the API profile):
# SF_ACME_USERNAME=...
# SF_ACME_PASSWORD=...
# SF_ACME_SECURITY_TOKEN=...

# Override the Parquet output directory so the local probe doesn't try to
# write to /mnt/session/outputs (which only exists on the Railway image).
SESSION_OUTPUT_DIR=/tmp/gtm-smoke-probe

# ─── Check C: Quick Answer agent ─────────────────────────────────────────
# Anthropic Managed Agents credentials. The probe creates a fresh single-turn
# session against the Quick Answer agent and asks it to echo "smoke-probe-ok".
ANTHROPIC_API_KEY=sk-ant-...
QUICK_AGENT_ID=agent_...
ENVIRONMENT_ID=env_...

# ─── Persistence + admin DM (optional locally) ───────────────────────────
# When DATABASE_URL is set, the probe inserts a row into smoke_probe_runs so
# the daily cost digest's 7-day pass rate stays accurate. Locally you can
# leave it unset — the probe still runs end-to-end and prints its result to
# stdout, just without persisting.
DATABASE_URL=

# When SLACK_BOT_TOKEN + SLACK_ADMIN_USER_IDS are set, the probe DMs the
# PASS/FAIL/INCONCLUSIVE template to admins. To avoid pinging the team
# during local debugging, pass `--no-dm`:
#   python -m orchestrator.smoke_probe --local --no-dm --check all
SLACK_BOT_TOKEN=
SLACK_ADMIN_USER_IDS=

# ─── Kill switch (read at orchestrator boot, NOT by the CLI) ─────────────
# The CLI always runs all requested checks; this env var only controls
# whether main.py's startup gate runs the probe at all.
SMOKE_PROBE_ENABLED=true
