# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Managed Agent IDs (from setup_agents.py output). `python agents/setup_agents.py`
# creates and prints all 11 roster agents plus the environment and both memory
# stores; paste each printed line here. (Prompt Engineer, RFP Responder, RFP
# Reviewer, and the Watcher are provisioned separately via their provision_*.py
# scripts — see docs/getting-started.md.)
ENVIRONMENT_ID=env_...
COORDINATOR_ID=agent_...
DREAM_AGENT_ID=agent_...
# Quick Answer agent (Sonnet 4.6) — single-fact Slack lookups. The
# canonical env-var name is ``QUICK_AGENT_ID``. ``orchestrator/config.py``
# also accepts the legacy ``QUICK_ANSWER_ID`` as a backward-compat
# fallback (decision row #18 from Plan #44 autoplan). The CI deploy
# workflow uses ``QUICK_ANSWER_ID`` to match the existing verify gate.
# Set whichever name your environment already uses — both resolve.
QUICK_AGENT_ID=agent_...
# Specialist + reasoning sub-agents (in the Coordinator's multiagent roster).
# All created and printed by agents/setup_agents.py — the orchestrator reads
# each one (slack_bot.py / anthropic_webhooks.py) to label sub-agent threads.
PIPELINE_MONITOR_ID=agent_...
SALES_MONITOR_ID=agent_...
POSTSALES_MONITOR_ID=agent_...
STATISTICIAN_ID=agent_...
CHART_DESIGNER_ID=agent_...
ADVERSARIAL_REVIEWER_ID=agent_...
CROSS_DOMAIN_SYNTHESIZER_ID=agent_...
METHODOLOGY_STORE_ID=memstore_...
HEALTH_STORE_ID=memstore_...

# Writing Agent (Haiku 4.5) — primary prose composer for user-facing copy.
# Created by `setup_agents.py` (printed as WRITING_AGENT_ID; provision_writing_
# agent.py remains for rotation). Copy the printed ID here AND to Railway. When unset, the Coordinator falls through to direct
# post_report (renderer + prose_polish safety net) instead of delegating prose
# composition to the Writing Agent — output ships without Haiku-quality prose.
WRITING_AGENT_ID=agent_...

# Prompt Engineer (Sonnet 4.6) — pre-flight question refinement. Reads
# /{portco}/instructions.md, injects standing data rules, and emits an
# improved prompt + plan + expected_output for the Slack ack message.
# Provision once with `python agents/provision_prompt_engineer.py`, copy
# the printed ID here AND to Railway. When unset, the orchestrator skips
# preprocessing and the Coordinator session uses the raw user question.
PROMPT_ENGINEER_ID=agent_...

# RFP Responder (Opus 4.8) — drafts RFP responses by pulling product
# context from Kapa and customer / market context from Salesforce.
# Standalone agent — NOT part of the Coordinator's multi-agent roster.
# Triggered when a file is uploaded to the dedicated RFP Slack channel.
# Provision once with `python agents/provision_rfp_agent.py`, then set
# both env vars below. RFP_CHANNEL_ID is the Slack channel ID for the
# dedicated RFP intake channel — any file_share event in that channel
# routes to orchestrator/rfp_runner.py instead of the question pipeline.
# When either is unset, the RFP path is disabled and file uploads in any
# channel are ignored; the existing question pipeline is unaffected.
RFP_RESPONDER_ID=agent_...
RFP_CHANNEL_ID=C0123456789

# RFP Reviewer (Opus 4.8) — quality gate the RFP Responder calls via
# the `review_rfp_draft` custom tool BEFORE its final Slack summary.
# Runs a six-check rubric (citation coverage, commitment leakage,
# marketing-speak, Kapa fact spot-checks, named customer verification,
# flag accuracy) and returns PASS / REVISE. The Responder revises up
# to 2x on REVISE before falling through with [REVIEW_INCOMPLETE].
# Provision once with `python agents/provision_rfp_reviewer_agent.py`.
# When unset, the review tool returns ok=false and the Responder
# treats that as a soft PASS — the draft still ships, just without
# the quality gate.
RFP_REVIEWER_ID=agent_...

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL_ID=C0123456789
SLACK_NOTIFY_USER_IDS=U0123456789,U9876543210
# Comma-separated Slack user IDs with admin privileges. These users gate
# privileged slash commands and receive admin-only DMs (catastrophic-failure
# notices, cost digests, drift watch lines). Leave empty to disable admin DMs.
SLACK_ADMIN_USER_IDS=U0123456789

# Postgres. Railway's Postgres add-on injects DATABASE_URL automatically;
# set it manually for local dev. The schema auto-bootstraps at boot
# (db_adapter.ensure_schema + orchestrator/migrations/*.sql) — no manual psql.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Portco config for git-based deploys (Railway/Docker). portco_config.json is
# gitignored (it holds your portco data), so it is NOT in the image build
# context. Provide it here as raw JSON or base64-encoded JSON and
# portco_registry loads it at runtime. Leave empty for local dev (it reads
# portco_config.json from disk) or to run on the built-in acme example.
PORTCO_CONFIG_JSON=

# Salesforce, per portco. The env-var NAMES are declared in
# portco_config.json -> portcos.<key>.data_sources.crm.sf_credentials, and the
# live query path (orchestrator/session_runner._get_sf_client) reads them.
# <PORTCO> is the uppercased portco key (acme -> ACME). OAuth client-credentials
# is the preferred path:
#   1. Create a Connected App in Salesforce Setup, enable OAuth.
#   2. Use the client-credentials flow (consumer key + secret + My Domain).
SF_CONSUMER_KEY_ACME=3MVG9...
SF_CONSUMER_SECRET_ACME=...
SF_DOMAIN_ACME=https://your-org.my.salesforce.com
#
# Anthropic MCP vault holding the Salesforce credentials for the live SF MCP
# path (read by orchestrator/config.py and referenced as `vault_id` in
# portco_config.json). Create the vault via the Anthropic Console / API and
# attach SF credentials with `python bin/add-sf-vault-credential.py`; paste
# the resulting `vlt_...` id here AND into portco_config.json. See
# docs/getting-started.md for the full mechanics. Leave empty if you only use
# the dump_sf_query / OAuth path (SF_MCP_VIA_VAULT=false).
ACME_VAULT_ID=
#
# SF OAuth credentials that `bin/add-sf-vault-credential.py` loads INTO the
# vault above. These are DISTINCT from the SF_CONSUMER_KEY_ACME direct path —
# fill them only if you provision the MCP vault (SF_MCP_VIA_VAULT=true). See
# docs/getting-started.md "Salesforce MCP vault" for the OAuth app setup.
# SF_ACME_CLIENT_ID=3MVG9...
# SF_ACME_CLIENT_SECRET=...
# SF_ACME_REFRESH_TOKEN=5Aep...
# SF_ACME_ACCESS_TOKEN=
# SF_ACME_TOKEN_ENDPOINT=https://login.salesforce.com/services/oauth2/token
#
# Optional SOAP fallback (only if you are not using OAuth client-credentials):
# SF_USERNAME_ACME=gtm-bot@your-org.example.com
# SF_PASSWORD_ACME=...
# SF_TOKEN_ACME=...
#
# To add another portco, copy this block with the new uppercased key
# (e.g. SF_CONSUMER_KEY_DELTA=...) and add the matching portco_config.json entry.

# Schedule (cron expressions, Pacific time)
DREAM_SCHEDULE_CRON=0 20 * * 0
INVESTIGATION_SCHEDULE_CRON=0 9 * * 1
TIMEZONE=America/Los_Angeles

# --- Plan #35 — Cost tracking and reporting (Anthropic Admin API) ---
# Required for the daily Admin Usage & Cost API pull. Only org admins can
# mint one (Anthropic Console → Settings → API Keys → Admin keys).
# Format: sk-ant-admin...
# Reminder: this app runs on Railway, not local — set this as a Railway
# env var, not just in your local .env. When unset, the cost reconciliation
# job logs a degraded-mode warning and continues with local estimates only.
ANTHROPIC_ADMIN_KEY=sk-ant-admin-...

# --- Plan #36 — Batch processing kill-switch ---
# When true, self_heal and self_improve route through Anthropic's Batches
# API (50% off, async). When false (default), both call sites stay realtime.
BATCH_PROCESSING_ENABLED=false

# --- Plan #49 — Channel description push kill switch ---
# When false, channel_descriptions.push_channel_description() is a no-op.
# Default: true. Read at call time so flipping takes effect on the next
# call (no container restart). Use to disable the event-driven + cron
# channel-purpose updates if templates regress or unexpected drift
# appears in production.
# CHANNEL_DESC_PUSH_ENABLED=true

# --- Plan #37 — Compresr prompt-compression integration ---
# COMPRESR_API_KEY format: cmp_... Set as a Railway env var (mint from
# https://compresr.ai dashboard). When unset but any COMPRESS_*_ENABLED
# flag below is true, the affected site is force-disabled with a warning.
COMPRESR_API_KEY=cmp_...
# Per-site enable flags. All default to false — flip individually after the
# evaluation loop in Plan #37 step 4 clears.
COMPRESS_SELF_HEAL_ENABLED=false
COMPRESS_SELF_IMPROVE_ENABLED=false
COMPRESS_ADHOC_KICKOFF=false

# Plan #44 Task #11 — Limited networking env (shadow rollout)
# ENVIRONMENT_ID points at the active env. ENVIRONMENT_ID_LIMITED is
# the shadow env created via bin/provision-limited-env.py; flip
# ENVIRONMENT_ID to its value after bake passes.
ENVIRONMENT_ID_LIMITED=
LIMITED_NETWORKING_SHADOW_PCT=0

# Plan #44 Task #17 — SF MCP via vault (shadow flag)
# When false (default), Specialists use dump_sf_query (proven path).
# When true, Specialists use vault-backed SF MCP server. Flipping
# this flag requires re-running update_subagent_tools.py and
# republishing the Coordinator multiagent roster.
SF_MCP_VIA_VAULT=false

# --- Plan #44 Task #22 — MCP auto-approve allowlist ---
# Comma-separated list of MCP server names allowed to auto-approve when the
# agent emits an mcp_tool_use event with evaluated_permission="ask".
# Empty by default — today no MCP servers are attached in production
# (Iter3 removed them in favor of dump_sf_query). If Bundle D's vault-SF
# work re-enables the Salesforce MCP path, add the SF server name here.
# Anything not on this list logs UNRECOGNIZED_MCP_SERVER + admin-DMs and
# is NOT auto-approved.
MCP_AUTO_APPROVE_ALLOWLIST=

# --- Plan #44 Task #14 — Anthropic webhooks ---
# Mint this when you create the subscription via
# `bin/subscribe-webhooks.py --apply`. Required for the
# /webhooks/anthropic HTTP handler to verify HMAC signatures. When
# unset, the handler returns 400 for every request.
ANTHROPIC_WEBHOOK_SIGNING_KEY=
# Public URL the webhook subscription points at (your Railway URL +
# `/webhooks/anthropic`). Used by `bin/subscribe-webhooks.py` to
# register the subscription.
ANTHROPIC_WEBHOOK_URL=

# --- Plan #44 Task #15 — /stop command ---
# Kill switch for the /stop slash command. Defaults to true; set to
# false (via env var or `/flag STOP_COMMAND_ENABLED false`) to disable
# the command without redeploying. Plan #44 Task #24 lets you flip this
# from Slack itself.
STOP_COMMAND_ENABLED=true

# --- Plan #42 PR2 — pre-deploy smoke probe ---
# When true (default), the container blocks /ready=200 until the smoke probe
# passes (see SMOKE_PROBE_LEVEL below for which checks). A failing probe
# leaves /ready=503; Railway's healthcheckTimeout fires and the deploy is
# marked failed, holding the previous image.
# When false, /ready returns 200 immediately and an admin DM warns the
# deploy was NOT validated. Operate the kill switch from Railway env to
# bypass during an incident — no code change needed.
SMOKE_PROBE_ENABLED=true

# --- Plan #44 Task #20 — smoke probe level ---
# Controls how thoroughly the pre-deploy probe exercises live dependencies.
# Allowed values (case-insensitive): off | quick | full
#
#   off    Probe skipped entirely; /ready returns 200 immediately. Use
#          during incident debugging when the probe itself is suspect.
#          Distinct from SMOKE_PROBE_ENABLED=false: ``off`` still writes a
#          row to smoke_probe_runs so the flip is auditable.
#   quick  (default) Checks A+B+C — build_commit match, dump_sf_query,
#          Quick Answer agent echo. ~$0.01/deploy.
#   full   Checks A+B+C+D — adds a trivial Coordinator multiagent turn so
#          a sub-agent prompt regression or stale multiagent pin surfaces
#          before the deploy goes green. ~$0.05/deploy. Use after sub-agent
#          prompt changes or whenever Coordinator routing is suspect.
#
# Bundle E (Plan #44 Task #24) lets you flip this from Slack at 2am:
#   /flag SMOKE_PROBE_LEVEL full
# The Postgres-backed override wins over this env var and survives the
# next redeploy.
SMOKE_PROBE_LEVEL=quick

# --- Kapa — Acme internal knowledge base ---
# Kapa.ai gives the Coordinator / Quick Answer / Dream / Post-Sales /
# Cross-Domain agents a knowledge-base search over Acme's Confluence +
# Jira + public docs + Slack archive. Used for product/engineering
# change-context.
#
# Dispatched as a custom tool (``search_knowledge_base``)
# against the Kapa REST streaming endpoint
# (``api.kapa.ai/query/v1/projects/<id>/chat/stream/``) via
# ``orchestrator/kapa_rest_tool.py``. No MCP server, no vault — Kapa's
# hosted MCP server requires OAuth and Kapa support confirmed they will
# not provide M2M OAuth client credentials, so the REST path is the
# permanent solution.
#
# Two env vars required:
#
# 1. KAPA_ACME_API_KEY — minted in the Kapa Acme tenant
#    (app.kapa.ai, Project Settings → API Keys). Format roughly
#    "<prefix>.<token>". Works as X-API-KEY header on the REST endpoint.
#    Rate limit: 20 req/min per key for the Chat endpoint (Retrieval is
#    60 req/min — we don't use that one). Read at session runtime by
#    ``orchestrator/kapa_rest_tool.py``.
#
# 2. KAPA_ACME_PROJECT_ID — the Kapa project UUID for the Acme
#    Internal tenant. Pull from the curl example in the Kapa console:
#    https://api.kapa.ai/query/v1/projects/<THIS_ID>/chat/ — the
#    <THIS_ID> path segment is the value to paste below.
#    Leave EMPTY when unset: config.py reads it with a default of "" and
#    treats any non-empty value as a real project ID, so a placeholder
#    string here would be mistaken for a configured tenant.
KAPA_ACME_API_KEY=
KAPA_ACME_PROJECT_ID=

# --- Watcher Agent (optional) ---
# Background agent that watches for and triages issues. Disabled by default.
# Set WATCHER_ENABLED=true and provide the two IDs to enable it. Provision the
# agent with `python agents/provision_watcher_agent.py` (prints WATCHER_AGENT_ID).
# WATCHER_GH_TOKEN is a GitHub token the watcher uses for repo operations.
WATCHER_ENABLED=false
WATCHER_AGENT_ID=agent_...
WATCHER_GH_TOKEN=

# --- Snapshot retention: Parquet cold archive (incident 2026-06-16) ---
# Tier 2 of the snapshot retention model (orchestrator/snapshot_archive.py).
# After each nightly sync the full raw rows are written to dated Parquet and
# uploaded to an S3-compatible bucket (a Railway bucket in prod), keeping the
# complete row-level history FOREVER off the Postgres volume while the hot
# copy in Postgres ages out after RAW_HOT_WINDOW_DAYS (default 60).
#
# OPTIONAL. If ARCHIVE_BUCKET_ENABLED is false or creds are unset, archiving
# is a no-op and the hot-window purge falls back to a rollup-only guarantee
# (daily_metrics kept forever; raw drill-down bounded to the hot window).
#
# Railway: create an object-storage bucket on the project, then copy its
# S3-compatible endpoint + access key + secret into the Railway service
# Variables (NOT local .env for the real secret).
ARCHIVE_BUCKET_ENABLED=false
ARCHIVE_S3_ENDPOINT=
ARCHIVE_S3_BUCKET=
ARCHIVE_S3_ACCESS_KEY_ID=
ARCHIVE_S3_SECRET_ACCESS_KEY=
ARCHIVE_S3_REGION=auto
ARCHIVE_S3_PREFIX=gtm-archive
# Days the bulky raw child rows stay hot in Postgres before the archive-gated
# purge drops them (snapshots metadata + daily_metrics are kept forever).
RAW_HOT_WINDOW_DAYS=60
